# insta-wizbee 환경 변수 템플릿
# 실제 값은 .env (gitignore 됨) 에 채우세요. 토큰은 절대 커밋 금지.

# ----- Instagram Graph API -----
INSTA_ACCOUNT_ID=17841427998042847
INSTA_ACCESS_TOKEN=            # 장기 Page Access Token (60일+). Meta Developer Console에서 발급.

# ----- Firebase (로컬 개발 시) -----
# 서비스 계정 JSON 파일 경로 또는 JSON 문자열 그대로.
# GitHub Actions 에서는 Secrets 의 FIREBASE_SERVICE_ACCOUNT 로 대체.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# ----- Slack (approver 봇용, 선택) -----
SLACK_WEBHOOK_URL=
